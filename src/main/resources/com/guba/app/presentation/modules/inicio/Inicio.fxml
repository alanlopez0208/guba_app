<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.guba.app.controllers.inicio.InicioController"
            styleClass="dashboard-container">
    <top>
        <VBox spacing="10" styleClass="header-section">
            <padding>
                <Insets top="20" right="20" bottom="10" left="20"/>
            </padding>
            <Text text="Dashboard - Panel de Control" styleClass="dashboard-title" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Text fx:id="txtResumen" text="Resumen general del sistema" style="-fx-font-size: 14px; -fx-fill: #666666;"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent;">
            <VBox spacing="20">
                <padding>
                    <Insets top="10" right="20" bottom="20" left="20"/>
                </padding>

                <!-- Tarjetas de estadísticas (sin dinero) -->
                <HBox spacing="15" alignment="CENTER">
                    <VBox styleClass="stat-card" alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS">
                        <Text fx:id="txtTotalEstudiantes" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-fill: #1B3765;"/>
                        <Text text="Estudiantes" style="-fx-font-size: 14px;"/>
                    </VBox>
                    <VBox styleClass="stat-card" alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS">
                        <Text fx:id="txtTotalMaestros" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-fill: #8B1D41;"/>
                        <Text text="Maestros" style="-fx-font-size: 14px;"/>
                    </VBox>
                    <VBox styleClass="stat-card" alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS">
                        <Text fx:id="txtTotalCarreras" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-fill: #2C5AA0;"/>
                        <Text text="Carreras" style="-fx-font-size: 14px;"/>
                    </VBox>
                    <VBox styleClass="stat-card" alignment="CENTER" spacing="5" HBox.hgrow="ALWAYS">
                        <Text fx:id="txtTotalGrupos" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-fill: #42517A;"/>
                        <Text text="Grupos" style="-fx-font-size: 14px;"/>
                    </VBox>
                </HBox>

                <!-- Primera fila de gráficos -->
                <HBox spacing="20" HBox.hgrow="ALWAYS">
                    <VBox HBox.hgrow="ALWAYS" styleClass="chart-container">
                        <PieChart fx:id="pieChartCarreras" title="Estudiantes por Carrera" prefHeight="300" legendSide="BOTTOM"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" styleClass="chart-container">
                        <PieChart fx:id="pieChartGenero" title="Distribución por Género" prefHeight="300" legendSide="BOTTOM"/>
                    </VBox>
                </HBox>

                <!-- Segunda fila de gráficos -->
                <HBox spacing="20" HBox.hgrow="ALWAYS">
                    <VBox HBox.hgrow="ALWAYS" styleClass="chart-container">
                        <BarChart fx:id="barChartEstudiantesSemestre" title="Estudiantes por Semestre" prefHeight="300" legendVisible="false">
                            <xAxis>
                                <CategoryAxis label="Semestre" side="BOTTOM"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Cantidad" side="LEFT"/>
                            </yAxis>
                        </BarChart>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" styleClass="chart-container">
                        <BarChart fx:id="barChartEstudiantesGeneracion" title="Estudiantes por Generación" prefHeight="300" legendVisible="false">
                            <xAxis>
                                <CategoryAxis label="Generación" side="BOTTOM"/>
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Cantidad" side="LEFT"/>
                            </yAxis>
                        </BarChart>
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
